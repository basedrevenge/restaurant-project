d","value":"760571"}]},{"id":9,"placement":"inline-2","params":[{"key":"placementId","value":"760572"}]},{"id":9,"placement":"inline-3","params":[{"key":"placementId","value":"760573"}]},{"id":9,"placement":"inline-4","params":[{"key":"placementId","value":"760574"}]},{"id":9,"placement":"inline-5","params":[{"key":"placementId","value":"760575"}]},{"id":9,"placement":"vb-2","params":[{"key":"placementId","value":"760577"}]},{"id":9,"placement":"hb-low","params":[{"key":"placementId","value":"760578"}]},{"id":9,"placement":"vb-gal","params":[{"key":"placementId","value":"760579"}]},{"id":9,"placement":"inline-quiz","params":[{"key":"placementId","value":"760576"}]},{"id":30,"placement":"inread","params":[{"key":"placementId","value":"101570"}]},{"id":30,"placement":"inline-1","params":[{"key":"placementId","value":"103480"}]},{"id":30,"placement":"inline-2","params":[{"key":"placementId","value":"103481"}]},{"id":30,"placement":"inline-3","params":[{"key":"placementId","value":"103482"}]},{"id":30,"placement":"inline-4","params":[{"key":"placementId","value":"103483"}]},{"id":30,"placement":"inline-5","params":[{"key":"placementId","value":"103484"}]},{"id":30,"placement":"inline","params":[{"key":"placementId","value":"103485"}]},{"id":28,"placement":"inline-topics","params":[{"key":"placementId","value":"73-Hw7Km"}]},{"id":28,"placement":"vb-2","params":[{"key":"placementId","value":"73-Wl5Bg"}]},{"id":28,"placement":"inline-1","params":[{"key":"placementId","value":"73-Dq3As"}]},{"id":28,"placement":"inline-2","params":[{"key":"placementId","value":"73-Hz3Xc"}]},{"id":28,"placement":"inline-3","params":[{"key":"placementId","value":"73-Mv2Do"}]},{"id":28,"placement":"inline-4","params":[{"key":"placementId","value":"73-Vr3Hj"}]},{"id":28,"placement":"inline-5","params":[{"key":"placementId","value":"73-Yw2Vl"}]},{"id":28,"placement":"inline","params":[{"key":"placementId","value":"73-Bm1Qh"}]},{"id":28,"placement":"hb-low-article","params":[{"key":"placementId","value":"73-Rk3Pl"}]},{"id":28,"placement":"hb-low","params":[{"key":"placementId","value":"73-Fl5Pa"}]},{"id":28,"placement":"inline-quiz","params":[{"key":"placementId","value":"73-Bm1Qh"}]},{"id":43,"placement":"inline-1","params":[{"key":"placementId","value":"319350"}]},{"id":43,"placement":"inline-2","params":[{"key":"placementId","value":"319354"}]},{"id":43,"placement":"inline-3","params":[{"key":"placementId","value":"319356"}]},{"id":43,"placement":"inline-4","params":[{"key":"placementId","value":"319358"}]},{"id":43,"placement":"inline-5","params":[{"key":"placementId","value":"319360"}]},{"id":43,"placement":"inline","params":[{"key":"placementId","value":"319362"}]},{"id":43,"placement":"vb-2","params":[{"key":"placementId","value":"319364"}]},{"id":43,"placement":"inline-quiz","params":[{"key":"placementId","value":"319370"}]},{"id":43,"placement":"hb-low-article","params":[{"key":"placementId","value":"319386"}]},{"id":43,"placement":"hb-low","params":[{"key":"placementId","value":"319388"}]},{"id":43,"placement":"inread","params":[{"key":"placementId","value":"326530"}]},{"id":43,"placement":"vb-gal","params":[{"key":"placementId","value":"319390"}]},{"id":31,"placement":"inline-1","params":[{"key":"placementId","value":"7838"}]},{"id":31,"placement":"inline-2","params":[{"key":"placementId","value":"7839"}]},{"id":31,"placement":"inline-3","params":[{"key":"placementId","value":"7840"}]},{"id":31,"placement":"inline-4","params":[{"key":"placementId","value":"7841"}]},{"id":31,"placement":"inline-5","params":[{"key":"placementId","value":"7842"}]},{"id":31,"placement":"inline","params":[{"key":"placementId","value":"7843"}]},{"id":31,"placement":"vb-2","params":[{"key":"placementId","value":"7844"}]},{"id":17,"placement":"inline","params":[{"key":"id","value":"28860"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"sticky","params":[{"key":"id","value":"28864"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"vb-2","params":[{"key":"id","value":"28861"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"vb-gal","params":[{"key":"id","value":"28863"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"inline-1","params":[{"key":"id","value":"28855"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"inline-2","params":[{"key":"id","value":"28856"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"inline-3","params":[{"key":"id","value":"28857"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"inline-4","params":[{"key":"id","value":"28858"},{"key":"pid","value":"62177"}]},{"id":17,"placement":"inline-5","params":[{"key":"id","value":"28859"},{"key":"pid","value":"62177"}]}]},"Geo":{"geo":"-1","country":"RU","geoIsReady":false},"Subscription":{"success":false,"error":""},"SubscriptionPopup":{"success":false,"error":""},"CookiesPopup":{"showCookiesPopup":true,"cookieValue":null},"ABExperiments":{"experiments":[],"userGoals":{}},"Magazines":{"magazine":{"coverImage":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F20\u002F9c\u002F3d\u002F209c3d62859665b8c6469c7d2dde795e\u002F1723x2158_0xPrgyT7gs_8706506321775343015.jpg","url":"https:\u002F\u002Fwww.vokrugsveta.ru\u002Fpages\u002Fpodpiska-na-zhurnal-vokrug-sveta\u002F","organizationName":"ООО «Шкулёв Медиа Холдинг»","erid":"2SDnjdPcZPx","isAdvLabelEnable":true}},"ArticlesSearch":{"articles":[],"isLoading":false,"visible":false,"offset":0,"total":0,"term":""},"ModulesManager":{},"ArticlesPage":{"Articles":{"articles":[{"accessControl":{"canCommentsRead":"ALL","canCommentsWrite":"ALL"},"analytics":{"googleAnalytics":{"dimensions":[{"name":"themes","value":"Еда"},{"name":"dimension2","value":"Нина Беднар"},{"name":"dimension3","value":"2024-08-10 14:00:00"},{"name":"dimension4","value":"not evergreen"},{"name":"dimension5","value":"no"}],"id":"UA-61240096-1","params":{"enableSendReachGoal":false}},"googleTag":{"dimensions":[{"name":"title","value":"Нейростимуляторы на десерт: история и простой рецепт тирамису, чтобы порадовать себя и родных"},{"name":"id","value":"599771"},{"name":"type","value":"ArticlePage article"},{"name":"author","value":"Нина Беднар"},{"name":"publication_date","value":"10.08.2024"},{"name":"site_section","value":"Истории"},{"name":"flow","value":"nope"},{"name":"themes","value":"Еда"},{"name":"recipe","value":"yes"},{"name":"e_commerce","value":"no"}],"id":"G-5R8RGZGGS3"}},"attributes":["checked_by_proofreader","export_to_zen","evergreen","export_to_pulse","export_to_vk","export_to_ok","export_to_facebook","export_to_twitter","hide_publication_date"],"authors":[{"fullName":"Нина Беднар","hasPersonalPage":true,"id":19298,"jobTitle":"","photo":"","role":"text_author","url":"\u002Fauthors\u002Fnina-bednar\u002F"}],"characters":5043,"cities":[],"comments":{"comments":[],"parentsTotal":0,"total":0},"commercialInfo":null,"content":[{"group":null,"isHighlighted":false,"text":"\u003Cp\u003E«Тебе грустно? Съешь тирамису!»&nbsp;— этот совет можно услышать от жизнерадостных итальянцев. Кстати, название этого популярного десерта буквально переводится как «подбодри меня». Улучшить настроение помогают природный нейростимулятор кофеин (кофе и какао), а также глюкоза (сахар) и лецитин (куриные яйца), содержащиеся в тирамису. Для дополнительного эффекта в эту смесь добавляют бисквиты, пропитанные алкоголем. Впрочем, ром, десертное вино или ликер&nbsp;— желательный, но необязательный элемент.\u003C\u002Fp\u003E","type":"text"},{"alt":"","caption":"","description":"","group":null,"height":414,"meta":{"instagramPostId":"","origin":"Shutterstock\u002FFotodom.ru","style":null},"type":"image","url":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F36\u002Fc4\u002F63\u002F36c463a07faccdc485ce66a91cfb5c3f\u002F5000x3335_0x8WpCwYj0_5896890447979178943.jpg","watermarkId":0,"watermarkPreset":"standard","width":620},{"group":null,"isHighlighted":false,"text":"\u003Ch2\u003EИстория десерта\u003C\u002Fh2\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EСогласно официальной версии, тирамису появился относительно недавно. Считается, что его изобрели в Тревизо, городе в области Венето, в 1970-е годы. Но кто первым приготовил его в современной версии, вопрос спорный.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EНа авторство претендовали как минимум три человека&nbsp;— повара местных кафе \u003Cem\u003EAlle Beccherie\u003C\u002Fem\u003E, \u003Cem\u003EEl Toulà\u003C\u002Fem\u003E и \u003Cem\u003EAl Fogher\u003C\u002Fem\u003E. Однако в данном случае вряд ли можно отдать кому-либо пальму первенства, ведь этот рецепт принадлежит всем и никому.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EПомимо официальной версии есть множество легенд о происхождении тирамису, достоверность которых не проверить. К примеру, одна забавная и малоправдоподобная история приписывает изобретение похожего десерта некоему трактирщику. Чтобы избавить от похмелья постояльца, трактирщик смешал для него на завтрак кофе, сливки и яйца, взбитые с сахаром.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EДругая история рассказывает, что рецепт чудодейственного десерта пришел в голову одной венецианке, после того как свекровь принесла ей кофе с кремом сабайон, чтобы поддержать силы после трудных родов.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EВ третьей упоминается об итальянских солдатах Первой мировой, для укрепления сил и поднятия боевого духа употреблявших пропитанный алкоголем десерт перед отправкой на фронт.\u003C\u002Fp\u003E","type":"text"},{"blocks":[{"isHighlighted":false,"text":"\u003Ch3\u003EИНТЕРВЬЮ\u003Cbr\u003EФранческа Джули\u003C\u002Fh3\u003E","type":"text"},{"isHighlighted":false,"text":"\u003Cp\u003E\u003Cem\u003EУроженка Пизы, шеф-повар московского ресторана «Эль Гаучито» (в 2015 году. —&nbsp;Прим. Vokrugsveta.ru), рассказывает, за что итальянцы любят тирамису\u003C\u002Fem\u003E\u003C\u002Fp\u003E","type":"text"},{"left":{"group":null,"isHighlighted":false,"text":"\u003Cp\u003E\u003Cstrong\u003EВ каждом итальянском ресторане этот десерт есть в меню, но делают ли его дома?\u003C\u002Fstrong\u003E\u003C\u002Fp\u003E\u003Cp\u003EКонечно. Я готовлю каждую неделю, семья просит. Это такое же распространенное блюдо, как паста или лазанья.\u003Cbr\u003E\u003Cbr\u003E\u003Cstrong\u003EОт чего зависит соотношение крема и бисквита?\u003C\u002Fstrong\u003E\u003C\u002Fp\u003E\u003Cp\u003EКак правило, от личных предпочтений. Хотя чем больше бисквита, тем дешевле обходится десерт.\u003Cbr\u003E\u003Cbr\u003E\u003Cstrong\u003EДля тирамису используют только савоярди?\u003C\u002Fstrong\u003E\u003C\u002Fp\u003E\u003Cp\u003EНет, еще и бисквит пан-ди-спанья. Он более рыхлый по структуре. Его часто используют, когда готовят сразу большую порцию. Но я предпочитаю савоярди: у него вкус деликатнее.\u003Cbr\u003E\u003Cbr\u003E\u003Cstrong\u003EРецепт тирамису выглядит простым, но результат у всех разный. В чем секрет?\u003C\u002Fstrong\u003E\u003C\u002Fp\u003E\u003Cp\u003EИспользуйте свежие куриные яйца, лучше деревенские. По классическому рецепту их не подвергают тепловой обработке, так что стоит исключить неприятные последствия для здоровья. И еще: для воскресного обеда лучше приготовить тирамису накануне вечером, чтобы он постоял в холоде.\u003C\u002Fp\u003E","type":"text"},"right":{"alt":"","caption":"","description":"","group":null,"height":275,"meta":{"instagramPostId":"","origin":"\u003Cp\u003EГригорий Поляковский\u003C\u002Fp\u003E","style":null},"type":"image","url":"https:\u002F\u002Fn1s2.hsmedia.ru\u002F99\u002Fb5\u002Fbe\u002F99b5be1f4c88695e02303e8af908c850\u002F300x275_0xac120003_8295598101638651118.jpeg","watermarkId":0,"watermarkPreset":"standard","width":300},"type":"sideBySide"}],"group":null,"theme":"background_only","type":"group"},{"group":null,"items":[{"title":"Сладкий вихрь: история и рецепт яблочного штруделя","url":"https:\u002F\u002Fwww.vokrugsveta.ru\u002Fvs\u002Farticle\u002F8502\u002F"}],"title":"Читайте также","type":"links"},{"group":null,"isHighlighted":false,"text":"\u003Ch2\u003EГеография десерта\u003C\u002Fh2\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EС местом происхождения тирамису тоже не все ясно. Традиционные десерты, напоминающие его по своему составу, существовали в разных итальянских регионах&nbsp;— Венето, Тоскане, Эмилии-Романье&nbsp;— за несколько столетий до появления классического рецепта.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EПочему Венето? Потому что тирамису трудно представить без кофе. С этим напитком, который современные итальянцы пьют на завтрак, обед и ужин, их познакомили венецианцы, активно торговавшие с Востоком. В XVII веке они завезли кофейные зерна из Египта и открыли одно из первых европейских кафе. Стоит добавить крепкий черный кофе к популярному в Венеции крему сабайон, и тирамису почти готов. Напоминающая гоголь-моголь смесь с алкоголем и бисквитным печеньем савоярди служила венецианцам отличным средством для укрепления сил. Его нередко советовали употреблять молодоженам в медовый месяц.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EТоскана тоже предъявляет свои права. Согласно \u003Cem\u003EEnciclopedia della Cucina Italiana\u003C\u002Fem\u003E, десерт, по составу очень напоминавший тирамису, впервые приготовил некий сиенский повар в честь визита тосканского герцога Козимо III Медичи (1642–1723). Блюдо получило название «герцогский суп» (\u003Cem\u003Ezuppa del duca\u003C\u002Fem\u003E). Другой «суп», английский, с XVI века и поныне готовят в области Эмилия-Романья. Его можно считать двоюродным братом тирамису. Для пропитки бисквита при приготовлении «английского супа» используют местный ликер алкермес.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EГлавное отличие рецепта в том, что «английский суп» буквально пару минут запекают в духовке, а тирамису никогда не подвергают тепловой обработке. Он жара духовки не переносит, а любит холод. Классический же рецепт тирамису сложился в окончательном виде, когда к яичному крему добавили сыр маскарпоне из Ломбардии.\u003C\u002Fp\u003E","type":"text"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003EСегодня тирамису, соответствуя динамичному и изменчивому ритму времени, принимает любые формы. Может уместиться в огромной посуде или в маленькой креманке. Способен стать тортом или мороженым. В его состав добавляют на выбор ягоды, ром, коньяк, ликер амаретто и сицилийское десертное вино марсала. Словно алкогольно-кофеиновой смеси внутри него недостаточно, итальянцы, чтобы как следует взбодриться, нередко дополняют тирамису сладким вином типа муската, мальвазии или розолио. И конечно же, не забывают выпить чашечку кофе.\u003C\u002Fp\u003E","type":"text"},{"group":null,"items":[{"title":"Ромовая баба: история и королевский рецепт","url":"https:\u002F\u002Fwww.vokrugsveta.ru\u002Farticle\u002F215772\u002F"}],"title":"Читайте также","type":"links"},{"group":null,"recipe":{"category":"Десерты","cookTime":"30","createdAt":"2024-08-10T08:53:05.087Z","cuisine":"Итальянская","description":"\u003Cp\u003EИтальянский десерт для поднятия настроения\u003C\u002Fp\u003E","id":2346,"image":{"alt":"","caption":"","description":"","height":0,"meta":{"origin":"\u003Cp\u003EГригорий Поляковский\u003C\u002Fp\u003E","style":""},"url":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F5f\u002F6f\u002Fff\u002F5f6ffff92c22db5626fccd0cfa13c2af\u002F1280x777_0xKI5iwJIC_9783672919293093719.jpg","width":0},"ingredients":[{"ingredientList":[{"amount":"6","name":"желток яичный","unit":"шт."},{"amount":"500","name":"сыр маскарпоне","unit":"г"},{"amount":"500","name":"сливки 33-35%","unit":"мл"},{"amount":"250","name":"эспрессо","unit":"мл"},{"amount":"100","name":"печенье савоярди","unit":"г"},{"amount":"20","name":"какао-порошок без сахара","unit":"г"},{"amount":"","name":"ассорти ягодное","unit":"по вкусу"},{"amount":"","name":"листья мяты","unit":"по вкусу"}],"title":""},{"ingredientList":[{"amount":"340","name":"Сахарный песок","unit":"г"},{"amount":"100","name":"вода","unit":"мл"}],"title":"Для сиропа"}],"instructions":[{"description":"\u003Cp\u003EЖелтки сырых яиц взбить миксером до белизны и вязкой текстуры (около 10 минут). Приготовить сироп: налить в кастрюлю воду, добавить сахар, довести до кипения и варить 5–7 минут. Готовность определить кулинарным термометром: температура должна достичь 121 °С.\u003C\u002Fp\u003E","image":{"alt":"","caption":"","description":"","height":0,"meta":{"origin":"","style":""},"url":"","width":0}},{"description":"\u003Cp\u003EСироп смешать со взбитыми желтками, остудить до комнатной температуры и поставить в холодильник на 15–20 минут. Соединить маскарпоне со сливками и взбить миксером в плотную массу. Добавить к этой смеси взбитые желтки, тщательно перемешать. В креманку выложить часть крема.\u003C\u002Fp\u003E","image":{"alt":"","caption":"","description":"","height":0,"meta":{"origin":"\u003Cp\u003EГригорий Поляковский\u003C\u002Fp\u003E","style":""},"url":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F84\u002F33\u002Fa8\u002F8433a8df2d1a710cf35bdae372d5d1bf\u002F1000x415_0xYPsbtFEa_9712174521767989241.jpg","width":0}},{"description":"\u003Cp\u003EПеченье савоярди разрезать на половинки. Верхней частью опустить в остывший до комнатной температуры кофе эспрессо (в него можно добавить чайную ложку алкоголя&nbsp;— рома или ликера амаретто) и выложить поверх крема несколько штук.\u003C\u002Fp\u003E","image":{"alt":"","caption":"","description":"","height":0,"meta":{"origin":"","style":""},"url":"","width":0}},{"description":"\u003Cp\u003EПокрыть кремом, добавить второй слой печенья савоярди, на него выложить еще слой крема. Верх аккуратно разровнять и посыпать какао. Поставить на 3–4 часа в холодильник. Перед подачей можно украсить ягодами и листиком мяты.\u003C\u002Fp\u003E","image":{"alt":"","caption":"","description":"","height":0,"meta":{"origin":"\u003Cp\u003EГригорий Поляковский\u003C\u002Fp\u003E","style":""},"url":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F3f\u002F0c\u002F5d\u002F3f0c5d8e3a3907289e15a00c79998c53\u002F1000x415_0xkECXzwNI_7102042691174304121.jpg","width":0}}],"modifiedAt":"2024-08-10T08:53:35.984Z","name":"Тирамису","nutrition":{"calories":"","carbohydrateContent":"","fatContent":"","proteinContent":""},"projectKey":"VOKRUGSVETA","rating":5,"yield":"7"},"type":"recipe"},{"group":null,"isHighlighted":false,"text":"\u003Cp\u003E\u003Cem\u003E\u003Csub\u003EМатериал опубликован в январе 2015, частично обновлен в августе 2024\u003C\u002Fsub\u003E\u003C\u002Fem\u003E\u003C\u002Fp\u003E","type":"text"}],"contentSource":"","contentSourceId":3,"createdAt":"2015-01-04T09:55:56Z","currentPublishedAt":"2024-08-10T14:00:00Z","firstPublication":"2016-02-09T21:05:15Z","gamification":{"isShkulevBonusEnabled":false},"hasFixedNextArticle":false,"horizontalImage":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F35\u002F62\u002F54\u002F356254ee6ce12cd983fc02177405e640\u002F1920x1152_0xqzENJ7bD_7389050790121346573.jpg","id":599771,"inactiveTopics":[],"isActive":true,"isAdsDisabled":false,"isAuthorsHidden":false,"leadParagraph":"О происхождении тирамису существует множество легенд","legacyId":"","modifiedAt":"2025-01-17T05:57:10.609Z","pageMeta":{"amphtml":"","canonical":"https:\u002F\u002Fwww.vokrugsveta.ru\u002Farticle\u002F218824\u002F","description":"О происхождении тирамису существует множество легенд","h1":"Нейростимуляторы на десерт: история и простой рецепт тирамису, чтобы порадовать себя и родных","image":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F35\u002F62\u002F54\u002F356254ee6ce12cd983fc02177405e640\u002F1920x1152_0xqzENJ7bD_7389050790121346573.jpg","ogDescription":"О происхождении тирамису существует множество легенд","ogImage":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F51\u002F3b\u002Fa2\u002F513ba236a4abdc18c4685e021e7f68e6\u002F1200x630_0xfoEtbz4p_1398106809169682744.jpg","ogImageType":"image\u002Fjpeg","ogTitle":"Нейростимуляторы на десерт: история и простой рецепт тирамису, чтобы порадовать себя и родных","seoText":"","title":"Как приготовить тирамису: пошаговый рецепт для приготовления в домашних условиях","twitterDescription":"О происхождении тирамису существует множество легенд","twitterImage":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F51\u002F3b\u002Fa2\u002F513ba236a4abdc18c4685e021e7f68e6\u002F1200x630_0xfoEtbz4p_1398106809169682744.jpg","twitterTitle":"Нейростимуляторы на десерт: история и простой рецепт тирамису, чтобы порадовать себя и родных"},"partner":null,"projectKey":"VOKRUGSVETA","publishedAt":"2024-08-10T14:00:00Z","relatedEntities":[{"description":"Кулинария порой тесно связана с историей: например, некоторые десерты могут рассказать что-то интересное о прошлом разных стран и их правителей","id":605072,"image":"https:\u002F\u002Fn1s2.hsmedia.ru\u002F8d\u002F51\u002F1d\u002F8d511dd32afa1716ea86287f0992457a\u002F1000x600_0xac120003_6303950411626973977.jpg","labels":[],"title":"Сладкая история: 5 десертов с богатым прошлым","type":"article","url":"\u002Farticle\u002F280146\u002F"},{"description":"Некоторые из них имеют многовековую историю","id":603806,"image":"https:\u002F\u002Fn1s1.hsmedia.ru\u002F0b\u002F88\u002F41\u002F0b8841126899ec4a1d40eb2453d3237d\u002F1000x600_0xhcGSlsYO_5620276105830434270.jpg","labels":[],"title":"Во все сладкие: посмотрите на 10 удивительных десертов","type":"article","url":"\u002Farticle\u002F267778\u002F"},{"description":"«Лучший помощник дипломата — повар», — заметил как-то Талейран. Мастер политической интриги научил дипломатическим приемам своего шеф-повара. А тот приготовил шарлотку для императора Александра I","id":602735,"image":"https:\u002F\u002Fn1s1.hsmedia.ru\u002Fb4\u002F48\u002F24\u002Fb44824397b30326ea9e4f7aa4df8e339\u002F1920x1152_0xxLN9l3Ec_3708362487791746940.jpg","labels":[],"title":"Дипломатический дар: история и рецепт «русской» шарлотки по-парижски","type":"article","url":"\u002Farticle\u002F255879\u002F"},{"description":"Настоящий сицилиец не представляет воскресного семейного обеда без горы канноли на блюде. И, конечно же, каждый житель острова уверен, что лучший десерт готовит только его мама. Но вот история происхождения этого десерта менее очевидна","id":868486,"image":"https:\u002F\u002Fn1s2.hsmedia.ru\u002Fff\u002F55\u002Ff5\u002Fff55f5e8079e9208f84201c0aec3f845\u002F1200x720_0xac120004_12846116821676902626.jpeg","labels":[],"title":"В сердце Сицилии: история и рецепт традиционного десерта канноли","type":"article","url":"\u002Farticles\u002Fv-serdce-sicilii-istoriya-i-recept-tradicionnogo-deserta-kannoli-id868486\u002F"}],"slug":"neirostimulyatory-na-desert-istoriya-i-prostoi-recept-tiramisu-chtoby-poradovat-sebya-i-rodnykh","stats":{"comments":0,"hideViews":true,"publishedAt":"2016-02-09T21:05:15Z","updatedAt":"2024-08-10T14:00:00Z","views":27822,"viewsWithGallery":27822},"status":"REPUBLISHED","tags":[],"themes":[{"displayName":"Еда","id":929904,"url":"\u002Feda\u002Feda\u002F"},{"displayName":"Рецепт с историей","id":930208,"url":"\u002Feda\u002Frecept-s-istoriei\u002F"}],"title":"Нейростимуляторы на десерт: история и простой рецепт тирамису, чтобы порадовать себя и родных","topComments":{"comments":[],"total":0},"topics":[{"displayName":"Истории","id":1149,"isActive":true,"slug":"history","url":"\u002Fhistory\u002F"}],"type":"article","url":"\u002Farticle\u002F218824\u002F","viewOptions":{"loadNextArticle":"BY_BUTTON"},"yandexNewsTitle":""}],"loadingCount":0,"isEndOfList":false,"activeArticleIndex":0,"enableLegacyUrls":true,"enableComments":true,"isPersonalComments":false,"startupGalleryNumber":null,"startupGallerySlide":null,"projectKey":"WDAY","articlesLimit":4,"articleStats":{"comments":null,"views":null,"viewsWithGallery":null,"viewsPreviousYear":null,"viewsThisYear":null,"viewsWithGalleryPreviousYear":null,"viewsWithGalleryThisYear":null,"publishedAt":"","updatedAt":"","hideViews":true},"red